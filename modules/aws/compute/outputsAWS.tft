output "subnet_is" {
  description = "ID da subnet criada na AWS"
  value       = aws_subnet.Subnet_linux.id
}

output "security_group_id" {
  description = "Id da security group"
  value       = aws_security_group.sg-access-to-linux.id
}

output "vm_aws_ip" {
  description = "Ip da maquina virtual de AWS: "
  value       = aws_instance.vm.public_ip

}